# 서버 포트 (기본값: 5000)
PORT=5000

# MongoDB 연결 URI
# 로컬: mongodb://localhost:27017/order_bread
# Atlas: mongodb+srv://사용자:비밀번호@cluster0.xxxxx.mongodb.net/order_bread
MONGODB_URI=mongodb://localhost:27017/order_bread

# JWT 토큰 서명용 시크릿 (배포 시 반드시 강력한 값으로 변경)
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# 환경 (development | production)
# 배포 시 NODE_ENV=production 이면 JWT_SECRET 필수
NODE_ENV=development

# 프론트 허용 도메인(쉼표 구분)
# 예: https://order-bread.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
