# ===========================================
# 로컬 개발 서버 포트 (선택)
# ===========================================
# 기본 3000. 다른 Vite/프로세스가 3000을 쓰면 strictPort 때문에 실행이 막히므로,
# 그 프로세스를 끄거나 아래처럼 포트를 바꿉니다.
# VITE_DEV_PORT=3001

# ===========================================
# API URL
# ===========================================
# 로컬: 생략 시 /api (Vite proxy → localhost:5000)
#
# Vercel (권장, CORS 회피): 같은 도메인 /api → vercel.json rewrite → Cloudtype
#   빌드 시 VERCEL=1 이면 VITE_API_URL은 자동으로 무시됨(vite.config.js). 대시보드에 넣어도 덮어씀.
#   프록시 대상 URL 바뀌면 루트 vercel.json · client/vercel.json 의 destination 수정
#
# Vercel (브라우저→Cloudtype 직접): VITE_API_URL = Cloudtype 루트 (경로까지, 끝 /api 없음)
# VITE_API_URL=

# ===========================================
# Cloudinary 위젯 (이미지 업로드) 환경변수
# ===========================================
# 이 파일을 .env 또는 .env.local 로 복사 후 실제 값으로 수정하세요.
#
# 1. VITE_CLOUDINARY_CLOUD_NAME (필수)
#    - Cloudinary 대시보드: https://console.cloudinary.com
#    - 대시보드 상단/홈에 표시된 "Cloud name" 값
#    - 예: dx7abc123
#
# 2. VITE_CLOUDINARY_UPLOAD_PRESET (필수)
#    - Settings > Upload > Add upload preset
#    - Signing Mode: "Unsigned" 선택
#    - Preset name 입력 후 Save
#    - 예: order_bread_unsigned
#
# Vite는 VITE_ 접두사가 있는 변수만 클라이언트에 노출합니다.
# ===========================================

VITE_CLOUDINARY_CLOUD_NAME=dajfvansm
VITE_CLOUDINARY_UPLOAD_PRESET=order_bread
